# Scoped to ~/code/planetary/burlington/ via includeIf in ~/.gitconfig
# SSH-based commit signing using the 1Password-managed key "GitHub - hel-planetary"

[user]
	name = Hel Rabelo
	email = hel@planetary.co
	signingkey = ssh-rsa 

[github]
	user = hel-planetary

# New clones using plain github.com URLs in the burlingtonstores org
# automatically get the burlington SSH alias.
[url "git@github.com-burlington:burlingtonstores/"]
	insteadOf = git@github.com:burlingtonstores/
