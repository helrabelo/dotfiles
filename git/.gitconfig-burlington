# Scoped to ~/code/planetary/burlington/ via includeIf in ~/.gitconfig.
# This fragment loads AFTER .gitconfig-planetary (which also matches this nested
# path), so it must override every identity key planetary sets, or planetary's
# values leak in. Identity here is Hel's client-provisioned Burlington account;
# commits are SSH-signed with the Burlington key ("GitHub - planetary-hel-burlington").

[user]
	name = Hel Rabelo
	email = hrabelo1@burlington.com
	signingkey = ssh-rsa 

[gpg]
	format = ssh

[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
	gpgsign = true

[github]
	user = planetary-hel-burlington

# New clones using plain github.com URLs in the burlingtonstores org
# automatically get the burlington SSH alias.
[url "git@github.com-burlington:burlingtonstores/"]
	insteadOf = git@github.com:burlingtonstores/
