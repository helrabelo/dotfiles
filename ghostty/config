# Ghostty Configuration
theme = Dracula+
font-size = 24

# Word navigation: opt+arrow moves by word
keybind = alt+left=esc:b
keybind = alt+right=esc:f

# Word deletion: opt+backspace deletes last word
# esc:\x7f sends ESC+DEL, which .zshrc's `bindkey '\e\x7f' backward-kill-word` catches
keybind = alt+backspace=esc:\x7f

# Paste image from clipboard: cmd+shift+v types the `pi` function + enter
keybind = cmd+shift+v=text:pi\r
